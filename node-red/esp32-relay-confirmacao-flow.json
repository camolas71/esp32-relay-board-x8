    ]
  },
  {
    "id": "f7b8f0f7a8c10019",
    "type": "function",
    "z": "f7b8f0f7a8c10001",
    "name": "Texto ERRO",
    "func": "const r = msg.payload || {};\nmsg.payload = `ERRO: Relay ${r.relay} esperado=${r.expected} recebido=${r.got}`;\nreturn msg;",
    "outputs": 1,
    "timeout": "",
