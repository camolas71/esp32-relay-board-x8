  {
    "id": "f7b8f0f7a8c10012",
    "type": "function",
    "z": "f7b8f0f7a8c10001",
    "name": "Validar confirmacao",
    "func": "const cmd = msg.cmd || {};\nconst p = msg.payload || {};\n\nif (p.ok !== true || !Array.isArray(p.relays)) {\n    msg.confirmed = false;\n    msg.reason = \"Resposta sem formato esperado\";\n    return [null, msg];\n}\n\nconst idx = Number(cmd.ch) - 1;\nif (!Number.isInteger(idx) || idx < 0 || idx > 7) {\n    msg.confirmed = false;\n    msg.reason = \"Contexto cmd invalido\";\n    return [null, msg];\n}\n\nconst expected = Number(cmd.state) ? 1 : 0;\nconst got = Number(p.relays[idx]) ? 1 : 0;\n\nmsg.expected = expected;\nmsg.got = got;\nmsg.confirmed = expected === got;\n\nif (msg.confirmed) {\n    msg.payload = {\n        ok: true,\n        relay: idx + 1,\n        state: got,\n        uptime: p.uptime\n    };\n    return [msg, null];\n}\n\nmsg.payload = {\n    ok: false,\n    relay: idx + 1,\n    expected: expected,\n    got: got,\n    uptime: p.uptime\n};\nmsg.reason = \"Estado final nao corresponde ao comando\";\nreturn [null, msg];",
    "outputs": 2,
    "timeout": "",
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 1110,
    "y": 320,
    "wires": [
      [
        "f7b8f0f7a8c10013",
        "f7b8f0f7a8c10018"
      ],
      [
        "f7b8f0f7a8c10014",
        "f7b8f0f7a8c10019"
      ]
    ]
  },
