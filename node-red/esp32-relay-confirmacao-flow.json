  {
    "id": "f7b8f0f7a8c10018",
    "type": "function",
    "z": "f7b8f0f7a8c10001",
    "name": "Texto OK",
    "func": "msg.payload = `OK: Relay ${msg.payload.relay} -> ${msg.payload.state ? 'ON' : 'OFF'} (uptime ${msg.payload.uptime}s)`;\nreturn msg;",
    "outputs": 1,
    "timeout": "",
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 1310,
