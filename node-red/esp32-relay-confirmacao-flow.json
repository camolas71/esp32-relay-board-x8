[
  {
    "id": "f7b8f0f7a8c10001",
    "type": "tab",
    "label": "ESP32 Reles Confirmacao",
    "disabled": false,
    "info": "Controla os 8 reles e valida confirmacao pela resposta /api/status"
  },
  {
    "id": "f7b8f0f7a8c10010",
    "type": "function",
    "z": "f7b8f0f7a8c10001",
    "name": "Build URL + contexto",
    "func": "const base = \"http://192.168.1.181\";\n\nif (!msg.payload || typeof msg.payload !== \"object\") {\n    node.error(\"payload invalido: esperado objeto\", msg);\n    return null;\n}\n\nconst cmd = {\n    ch: Number(msg.payload.ch),\n    state: Number(msg.payload.state) ? 1 : 0\n};\n\nif (!Number.isInteger(cmd.ch) || cmd.ch < 1 || cmd.ch > 8) {\n    node.error(\"ch deve ser inteiro entre 1 e 8\", msg);\n    return null;\n}\n\nmsg.cmd = cmd;\nmsg.method = \"GET\";\nmsg.url = `${base}/api/relay?ch=${cmd.ch}&state=${cmd.state}`;\nreturn msg;",
    "outputs": 1,
    "timeout": "",
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 670,
    "y": 320,
    "wires": [
      [
        "f7b8f0f7a8c10011"
      ]
    ]
  },
  {
    "id": "f7b8f0f7a8c10011",
    "type": "http request",
    "z": "f7b8f0f7a8c10001",
    "name": "ESP32 API",
    "method": "use",
    "ret": "obj",
    "paytoqs": "ignore",
    "url": "",
    "tls": "",
    "persist": false,
    "proxy": "",
    "insecureHTTPParser": false,
    "authType": "",
    "senderr": true,
    "headers": [],
    "x": 880,
